@echo off
REM ============================================================
REM  핸드 골키퍼 실행 스크립트
REM  - 로컬 웹서버(localhost)를 띄우고 브라우저로 게임을 엽니다.
REM  - 카메라(getUserMedia)는 보안 컨텍스트가 필요해 file:// 로는
REM    작동하지 않으므로 반드시 이 스크립트로 실행하세요.
REM ============================================================
cd /d "%~dp0"

echo.
echo  ===========================================
echo    핸드 골키퍼 서버를 시작합니다...
echo    종료하려면 이 창에서 Ctrl + C 를 누르세요.
echo  ===========================================
echo.

REM 잠시 후 기본 브라우저로 게임 페이지 열기
start "" http://localhost:8000/index.html

REM 8000번 포트로 정적 파일 서버 실행
python -m http.server 8000
